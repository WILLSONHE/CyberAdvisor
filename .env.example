# B 站抓取配置（复制为 .env 并填写，勿提交 git）

# 必填
BILIBILI_SESSDATA=
bili_jct=
DedeUserID=
# 多 UP：mid:名称，逗号分隔（推荐）
BILIBILI_UPS=1420210197:青枫浦上Q,518715314:大弯区董事长
# 单 UP 兼容（二选一）
# UP_UID=1420210197

# ── 抖音 fetch tiktok（钱加贝等）────────────────────────
# 方式 A（推荐）：分项填写，从 Chrome Application → Cookies → douyin.com 复制
# DOUYIN_TTWID=          ← 必填；HttpOnly，列表 API 核心
# DOUYIN_SESSIONID=      ← 登录后有；6 个月全量需要
# DOUYIN_S_V_WEB_ID=     ← 建议填 verify_ 开头
# DOUYIN_PASSPORT_CSRF=  ← 可选
#
# 方式 B：整串 Cookie（DevTools → Network → aweme/post → Request Headers → Cookie）
# DOUYIN_COOKIE=
#
# 方式 C：整串写入 secrets/douyin.cookie（已 gitignore，与 .env 等价）
#
# DOUYIN_SEC_UID=MS4wLjABAAAA6DxQ0-ZPlNTXGX2vGEUfNisdS5ZassI0AwR_cPbOYy9kZKWbzq4tNFuT0EtFVarc
# DOUYIN_CREATOR=钱加贝
#
# 验证: python scripts/douyin_cookie_check.py

# 可选别名
# BILIBILI_BILI_JCT=
# BILIBILI_DEDEUSERID=

# ── 飞书 ─────────────────────────────────────────────
# 方式 A：群自定义机器人 Webhook（单向推送，推荐先配）
FEISHU_WEBHOOK_URL=

# 方式 B：开放平台应用 Bot（本机双向对话，需公网/穿透回调）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=          # 启用事件加密时填写
FEISHU_BOT_PORT=8765
# 若系统 HTTP_PROXY 指向已关闭的本地代理（Clash 等）导致 ConnectionRefused，Bot 默认忽略系统代理
# 需走代理时再显式设置：FEISHU_HTTP_PROXY=http://127.0.0.1:7890
# 可选：群 chat_id，用于 AI 模拟盘 tick 后发送「AI模拟交易日志.md」附件（Webhook 仅文本）
# FEISHU_NOTIFY_CHAT_ID=oc_xxxxxxxx

# 飞书 Bot 启动时建议 UTF-8（feishu_bot.bat 已设 PYTHONUTF8=1 / PYTHONIOENCODING=utf-8）
# 需 CURSOR_API_KEY；FEISHU_AGENT=0 关闭 agent 子命令
# Bot 在本机预抓取 vipdoc/模拟持仓嵌入 prompt；GitHub（CURSOR_CLOUD_REPO）可选
# FEISHU_AGENT=1
# FEISHU_AGENT_OUTPUT_DIR=
# daily.bat 完成后自动 agent sug 全员（11:30–13:00 早盘可用；午盘因 vipdoc .day 约 15:45+ 才更新，建议关闭自动、改 vipdoc 后手动 agent sug）
# FEISHU_AUTO_SUG=1

# 方式 C：daily.bat 从飞书云文档下载 持仓.xlsx（三选一，推荐 URL）
# FEISHU_PORTFOLIO_URL=https://xxx.feishu.cn/sheets/shtxxxxxxxx
# FEISHU_PORTFOLIO_TOKEN=shtxxxxxxxx
# FEISHU_PORTFOLIO_TYPE=sheet
# 持仓.xlsx 格式（首个工作表，持有人列必填）
# FEISHU_PORTFOLIO_NAME=持仓
# FEISHU_PORTFOLIO_FOLDER_TOKEN=fldxxxxxxxx

# ── AI 模拟盘 Cloud Agent（真实密钥只写在 .env）────────
# CURSOR_API_KEY=
# CURSOR_CLOUD_REPO=          # 可选；tick 已含本机 vipdoc/outlook，不依赖 GitHub
# CURSOR_CLOUD_REF=master
# AI_SIM_AGENT=1
# AI_SIM_AGENT_TIMEOUT=600

# ── 通达信本地日 K（A 股；提升 σ / 1/3/7 区间宽度）────
# TDX_VIPDOC=C:\new_tdx64\vipdoc          # A 股日 K + ds 扩展行情（minline 1 分钟在 vipdoc\ds\minline）
# TDX_T0002=C:\new_tdx64\T0002            # 客户端缓存/符号表（hq_cache）；K 线仍在 vipdoc 下
# TDX_VIPDOC_QH=C:\new_tdxqh\vipdoc   # 期货/期权；当前脚本未接入
# TUSHARE_TOKEN=                        # Tushare Pro（2000 积分）；收盘后补日 K / 新票 bootstrap（见 scripts/tushare_daily.py）
# 收盘后 ~15:50 手动：Cursor 指令 vipdoc → python scripts/vipdoc_refresh.py → 再 sug 全员 午盘

# ── LLM / sug 预算（Streamlit 侧边栏可覆盖 Wiki/数据/llm_budget.json）──
# LLM_BUDGET_USD=5                      # 单次 sug 硬上限（美元），默认 5
# GRAPH_PIPELINE_ENABLED=0              # 多 Agent Graph 编排（非 LangGraph）；0=仅 dry-run/开发
# 本地看板：dashboard.bat → Streamlit :8501
